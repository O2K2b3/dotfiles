{
  description = "home-manager standalone flake";

  inputs = {
    nixpkgs.url = "github:NixOS/nixpkgs/nixpkgs-unstable";
    home-manager = {
      url = "github:nix-community/home-manager";
      inputs.nixpkgs.follows = "nixpkgs";
    };
    nix-claude-code.url = "github:ryoppippi/nix-claude-code";
  };

  outputs = inputs@{ self, nixpkgs, home-manager, nix-claude-code, ... }:
    let
      system = "{{ if eq .chezmoi.arch "arm64" }}aarch64{{ else if eq .chezmoi.arch "amd64" }}x86_64{{ end }}-{{ .chezmoi.os }}";
      pkgs = import nixpkgs {
        inherit system;
        overlays = [ 
          (import ./overlays)
          nix-claude-code.overlays.default
        ];
      };
    in {
      homeConfigurations.{{ .chezmoi.username }} = home-manager.lib.homeManagerConfiguration {
        inherit pkgs;
        extraSpecialArgs = { inherit inputs; };
        modules = [ ./home.nix ];
      };
    };
}
