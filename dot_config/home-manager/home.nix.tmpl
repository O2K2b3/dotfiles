{ pkgs, lib, config, inputs, ... }:
{
  imports = [
    ./op.nix
    ./packages/nvim.nix
];


  nixpkgs.config.allowUnfreePredicate = pkg: builtins.elem (lib.getName pkg)[
    "claude"
    "1password-cli"
  ];

  home.username = "{{ .chezmoi.username }}";
  home.homeDirectory = "{{ .chezmoi.homeDir }}";
  home.stateVersion = "24.11";

  home.packages = with pkgs; [
    # 1Password CLI
    _1password-cli

    # custom packages
    (callPackage ./packages/gwq.nix { })
    # navigation / search
    ghq
    fzf
    zoxide
    peco

    # dev environments / build
    devenv
    chezmoi
    devbox
    uv
    pnpm
    gradle
    luarocks
    go-task

    # CI / automation
    act
    wrkflw

    # network tools
    arp-scan
    httpie
    wget
    rsync

    # data
    duckdb
    jq

    # file/dir/utility
    bat
    eza
    fd
    dust
    gibo

    # git
    git
    git-lfs
    gh
    lazygit
    (callPackage ./packages/keifu.nix { })

    # shell / prompt
    sheldon
    starship
    zsh-completions
    zsh-syntax-highlighting

    # terminal multiplexer
    tmux
    
    # shell
    zsh

    # llm-agents
    inputs.llm-agents.packages.${pkgs.system}.opencode
    inputs.llm-agents.packages.${pkgs.system}.herdr
  ];

  home.sessionVariables = {
      PNPM_HOME = "${config.home.homeDirectory}/.local/share/pnpm";
      EDITOR = "nvim";
  };

  home.sessionPath = [
    "${config.home.homeDirectory}/.local/share/pnpm/bin"
  ];

  programs.zsh = {
    enable = true;
    enableCompletion = true;
    shellAliases = {
      ls="eza -l --icons";
      la="eza -la";
      lsl="eza --icons -a -RT --level 2";
      v = "nvim";
      vi = "nvim";
      vim = "nvim";
      lg = "lazygit";
      gg = "keifu";
      claude-personal = "CLAUDE_CONFIG_DIR=~/.claude-personal claude";
    };
    initContent = ''
      # lang settings for hyper
      export LANG=en_US.UTF-8
      export LC_ALL=C.UTF-8

      # 履歴
      # メモリに保存される履歴の件数
      export HISTSIZE=1000
      # 履歴ファイルに保存される履歴の件数
      export SAVEHIST=100000
      ## ヒストリを共有
      setopt share_history
      setopt hist_expire_dups_first # 履歴を切り詰める際に、重複する最も古いイベントから消す
      setopt hist_ignore_all_dups   # 履歴が重複した場合に古い履歴を削除する

      # ghq and gwq worktree search
      function ghq-fzf() {
        local ghq_repos=$(ghq list -p)
        local target_dir=$(echo "$ghq_repos\n$worktree_repos" | fzf --query="$LBUFFER")

        if [ -n "$target_dir" ]; then
          BUFFER="cd $target_dir"
          zle accept-line
        fi

        zle reset-prompt
      }
      zle -N ghq-fzf
      bindkey "^]" ghq-fzf

    '';

    syntaxHighlighting.enable = true;
  };

  programs.starship = {
    enable = true;
    settings = {
    # Inserts a blank line between shell prompts
    add_newline = true;

    # Wait 100 milliseconds for starship to check files under the current directory.
    scan_timeout = 1000;

    # Replace the '❯' symbol in the prompt with '➜'
    # changed >>
    character = { 
    success_symbol = "[>>](bold green)"; # The 'success_symbol' segment is being set to '>>' with the color 'bold green'
    error_symbol = "[>>](bold red)";     # The 'error_symbol' segment is being set to '>>' with the color 'bold red'
    };
    # Disable the package module, hiding it from the prompt completely
    package.disabled = true;
    };
  };

  programs.fzf.enable = true;

  # Neovim is installed via packages/nvim.nix; its config is managed by
  # chezmoi under ~/.config/nvim (LazyVim). We intentionally do NOT use
  # programs.neovim here to avoid home-manager generating its own init.lua.

  programs.claude-code = {
    enable = true;
    package = pkgs.claude-code;
  };

  programs.home-manager.enable = true;
}
