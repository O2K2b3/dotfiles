#!/usr/bin/env bash
#
# Re-installs agent skills when lock files change.
# Triggered by chezmoi apply via the run_onchange_ filename prefix:
# chezmoi hashes the rendered output of this template and re-runs the script
# whenever that hash changes (i.e., when any embedded lock file content changes).
#
# Lock content embedded for change-detection (do not delete):
# --- BEGIN .skill-lock.json ---
# {{ include "dot_agents/dot_skill-lock.json" }}
# --- END .skill-lock.json ---

set -euo pipefail

LOCK_FILE="$HOME/.agents/.skill-lock.json"

if [ ! -f "$LOCK_FILE" ]; then
  echo "[skills] no $LOCK_FILE — skipping"
  exit 0
fi

if ! command -v jq >/dev/null 2>&1; then
  echo "[skills] jq not found — skipping (install via home-manager)"
  exit 0
fi

# --- npx skills (current primary manager) -----------------------------------
echo "[skills] restoring from .skill-lock.json"
jq -r '.skills | to_entries[] | "\(.key)\t\(.value.sourceUrl)"' "$LOCK_FILE" |
  while IFS=$'\t' read -r name url; do
    echo "  - $name  <-  $url"
    npx -y skills add "$url" -g -y -s "$name" </dev/null
  done

# --- gh skill install (future, optional) ------------------------------------
# Placeholder for when a `gh-skill` extension or similar is introduced:
# GH_LOCK="$HOME/.agents/.gh-skills.json"
# if [ -f "$GH_LOCK" ] && gh extension list 2>/dev/null | grep -q gh-skill; then
#   jq -r '.skills[].repo' "$GH_LOCK" | while read -r repo; do
#     gh skill install "$repo"
#   done
# fi

echo "[skills] done"
