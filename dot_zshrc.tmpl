# Amazon Q pre block. Keep at the top of this file.
[[ -f "${HOME}/Library/Application Support/amazon-q/shell/zshrc.pre.zsh" ]] && builtin source "${HOME}/Library/Application Support/amazon-q/shell/zshrc.pre.zsh"
# lang settings for hyper
export LANG=en_US.UTF-8
export LC_ALL=C.UTF-8

# 履歴
# メモリに保存される履歴の件数
export HISTSIZE=1000
# 履歴ファイルに保存される履歴の件数
export SAVEHIST=100000
## ヒストリを共有
setopt share_history
setopt hist_expire_dups_first # 履歴を切り詰める際に、重複する最も古いイベントから消す
setopt hist_ignore_all_dups   # 履歴が重複した場合に古い履歴を削除する

# histry search
# fzf history
function fzf-select-history() {
    BUFFER=$(history -n -r 1 | fzf --query "$LBUFFER" --reverse)
    CURSOR=$#BUFFER
    zle reset-prompt
    zle accept-line
}
zle -N fzf-select-history
bindkey '^r' fzf-select-history

# ghq and gwq worktree search
function ghq-fzf() {
  local ghq_repos=$(ghq list -p)
  local worktree_repos=$(find ~/ghq -mindepth 3 -maxdepth 3 -type d -name '*=*' 2>/dev/null)
  local target_dir=$(echo "$ghq_repos\n$worktree_repos" | fzf --query="$LBUFFER")

  if [ -n "$target_dir" ]; then
    BUFFER="cd ${target_dir}"
    zle accept-line
  fi

  zle reset-prompt
}
zle -N ghq-fzf
bindkey "^]" ghq-fzf


# starship config
eval "$(starship init zsh)"
# sheldon (plugin manager)
eval "$(sheldon source)"
{{ if not (contains "microsoft" .chezmoi.kernel.osrelease) -}}
# mise (skip on WSL)
eval "$(mise activate zsh)"
{{- end }}
# fizzy finder
eval "$(fzf --zsh)"

# pnpm
{{ if eq .chezmoi.os "darwin" -}}
export PNPM_HOME="$HOME/Library/pnpm"
{{- else -}}
export PNPM_HOME="$HOME/.local/share/pnpm"
{{- end }}
case ":$PATH:" in
  *":$PNPM_HOME/bin:"*) ;;
  *) export PATH="$PNPM_HOME/bin:$PATH" ;;
esac
# pnpm end

{{ if not (contains "microsoft" .chezmoi.kernel.osrelease) -}}
